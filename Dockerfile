# Step 1: استخدام نسخة CLI الرسمية من PHP كبيئة أساسية خفيفة
FROM php:8.2-cli

# Step 2: تحديد مجلد العمل الافتراضي داخل الحاوية
WORKDIR /app

# Step 3: نسخ كافة ملفات ومجلدات المشروع إلى داخل الحاوية (بما فيها index.php في الجذر)
COPY . .

# Step 4: فتح المنفذ 8081 المخصص لتصفح التطبيق
EXPOSE 8081

# Step 5: تشغيل السيرفر المدمج والإشارة إلى index.php مباشرة في الجذر
CMD ["php", "-S", "0.0.0.0:8081", "index.php"]
